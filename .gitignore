# =========================================================================
# DGJS Integrated .gitignore (Root, Spring Boot, React, IntelliJ, Windows/Mac)
# =========================================================================

# -------------------------------------------------------------------------
# OS & Common System Files
# -------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.log
*.tmp
*.swp

# -------------------------------------------------------------------------
# IntelliJ IDE Settings (Global & Local)
# -------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
out/
.shelf/

# -------------------------------------------------------------------------
# Backend: dgjs_server (Spring Boot / Gradle)
# -------------------------------------------------------------------------
**/dgjs_server/.gradle/
**/dgjs_server/build/
**/dgjs_server/bin/

# DB 및 API 키 등 민감한 설정 파일 (이후 실무 보안 증명용)
**/dgjs_server/src/main/resources/application-local.properties
**/dgjs_server/src/main/resources/application-prod.properties
# 만약 application.properties에 직접 비밀번호를 적을 예정이라면 아래 주석을 해제하세요.
# **/dgjs_server/src/main/resources/application.properties

# -------------------------------------------------------------------------
# Frontend: dgjs_platform (React / npm)
# -------------------------------------------------------------------------
**/dgjs_platform/node_modules/
**/dgjs_platform/build/
**/dgjs_platform/dist/

# 리액트 환경 변수 파일 (API 주소나 키값 은닉용)
**/dgjs_platform/.env
**/dgjs_platform/.env.local
**/dgjs_platform/.env.development.local
**/dgjs_platform/.env.test.local
**/dgjs_platform/.env.production.local

# npm log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*